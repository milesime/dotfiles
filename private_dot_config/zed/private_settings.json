{
  "auto_install_extensions": {
    "catppuccin": true,
    "git-firefly": true,
    "ocaml": true,
    "oxc": true,
    "toml": true,
    "tombi": true,
    "typst": true,
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "colorize_brackets": true,
  "completion_menu_item_kind": "symbol",
  "disable_ai": true,
  "document_folding_ranges": "on",
  "document_symbols": "on",
  "edit_predictions": {
    "allow_data_collection": "no",
  },
  "git_panel": {
    "dock": "left",
  },
  "languages": {
    "YAML": {
      "format_on_save": "on",
    },
    "Typst": {
      "format_on_save": "on",
    },
    "TypeScript": {
      "format_on_save": "on",
    },
    "TSX": {
      "format_on_save": "on",
    },
    "Shell Script": {
      "format_on_save": "on",
    },
    "Regex": {
      "format_on_save": "on",
    },
    "Reason Interface": {
      "format_on_save": "on",
    },
    "Reason": {
      "format_on_save": "on",
    },
    "Python": {
      "format_on_save": "on",
    },
    "Plain Text": {
      "format_on_save": "on",
    },
    "Odoc": {
      "format_on_save": "on",
    },
    "OCamllex": {
      "format_on_save": "on",
    },
    "OCaml MLX": {
      "format_on_save": "on",
    },
    "OCaml Interface": {
      "format_on_save": "on",
    },
    "Menhir": {
      "format_on_save": "on",
    },
    "Markdown-Inline": {
      "format_on_save": "on",
    },
    "JSONC": {
      "format_on_save": "on",
    },
    "JSON": {
      "format_on_save": "on",
    },
    "JSDoc": {
      "format_on_save": "on",
    },
    "JavaScript": {
      "format_on_save": "on",
    },
    "HTML": {
      "format_on_save": "on",
    },
    "Go Work": {
      "format_on_save": "on",
    },
    "Go Mod": {
      "format_on_save": "on",
    },
    "Git Rebase": {
      "format_on_save": "on",
    },
    "Git Ignore": {
      "format_on_save": "on",
    },
    "Git Config": {
      "format_on_save": "on",
    },
    "Git Commit": {
      "format_on_save": "on",
    },
    "Git Attributes": {
      "format_on_save": "on",
    },
    "Dune": {
      "format_on_save": "on",
    },
    "Diff": {
      "format_on_save": "on",
    },
    "CSS": {
      "format_on_save": "on",
    },
    "C": {
      "format_on_save": "on",
    },
    "C++": {
      "format_on_save": "on",
    },
    "Markdown": {
      "format_on_save": "on",
    },
    "TOML": {
      "format_on_save": "on",
    },
    "OCaml": {
      "format_on_save": "on",
    },
  },
  "lsp": {
    "ocamllsp": {
      "settings": {
        "extendedHover": {
          "enable": true,
        },
      },
    },
    "tinymist": {
      "initialization_options": {
        "preview": {
          "background": {
            "enabled": true,
          },
        },
      },
      "settings": {
        "formatterPrintWidth": 80,
      },
    },
  },
  "project_panel": {
    "dock": "left",
    "hide_root": true,
  },
  "semantic_tokens": "combined",
  "session": {
    "trust_all_worktrees": true,
  },
  "status_bar": {
    "active_encoding_button": "enabled",
    "line_endings_button": true,
  },
  "tabs": {
    "file_icons": true,
    "show_diagnostics": "all",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": {
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
  },
  "theme_overrides": {
    "Catppuccin Latte": {
      "border.variant": "#ccd0da",
    },
    "Catppuccin Frappé": {
      "border.variant": "#414559",
    },
    "Catppuccin Macchiato": {
      "border.variant": "#363a4f",
    },
    "Catppuccin Mocha": {
      "border.variant": "#313244",
    },
  },
  "title_bar": {
    "show_sign_in": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "ui_font_family": ".SystemUIFont",
}
